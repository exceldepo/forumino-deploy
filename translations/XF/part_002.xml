  <phrase title="bb_code_help_code_desc" version_id="1000015" version_string="1.0.0 Alpha 5"><![CDATA[Metni çeşitli programlama dillerinden birinde görüntüler, mümkün olan yerlerde söz dizimini vurgular.]]></phrase>
  <phrase title="bb_code_help_code_example" version_id="2000570" version_string="2.0.5"><![CDATA[Genel kod:
[CODE]Genel
kod[/CODE]

Zengin kod:
[CODE=rich][COLOR=red]Zengin[/COLOR]
kod[/CODE]

PHP kodu:
[CODE=php]echo $hello . ' world';[/CODE]

JS kodu:
[CODE=javascript]var hello = 'world';[/CODE]]]></phrase>
